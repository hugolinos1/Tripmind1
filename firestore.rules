/**
 * # Firestore Security Rules
 *
 * ## Core Philosophy
 * This ruleset enforces a strict user-ownership model. All user-generated data is
 * considered private and is only accessible by the user who created it. Access control
 * is primarily managed through path-based security, ensuring that users can only
 * interact with data within their own dedicated document tree.
 *
 * ## Data Structure
 * The entire data model is hierarchical, starting with the `/users/{userId}` collection.
 * All other user-specific data, such as trips, days, and events, are stored in
 * subcollections under their respective user document. This structure naturally
 * segregates user data and simplifies security rules.
 *
 * ## Key Security Decisions
 * - **Strict Ownership:** A user can only read or write data located under the path
 *   `/users/{their_auth_uid}`. There is no concept of shared or public data in this model.
 * - **No User Enumeration:** Listing the top-level `/users` collection is explicitly
 *   disallowed to protect user privacy and prevent enumeration attacks.
 * - **Path-Based Security:** Authorization for nested subcollections (trips, days, etc.)
 *   relies on the `{userId}` wildcard from the path. This is efficient and avoids
 *   costly `get()` calls to parent documents for ownership verification.
 * - **Relational Integrity:** While data shapes are flexible, rules enforce that
 *   documents created in subcollections contain the correct ID of their parent document,
 *   maintaining the integrity of relationships (e.g., a new Day document must have a `tripId`
 *   that matches the ID of the parent Trip). These relational IDs are immutable after creation.
 *
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the provided userId.
     * This is the primary function for enforcing document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * A robust check for update and delete operations.
     * It verifies ownership AND ensures the document already exists.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }


    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    /**
     * @description Controls access to a user's own profile document.
     * @path /users/{userId}
     * @allow (create) An authenticated user can create their own user profile document.
     * @deny (list) Another user cannot list all user profiles.
     * @principle Restricts access to a user's own data tree and prevents user enumeration.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Controls access to a user's collection of trips.
       * @path /users/{userId}/trips/{tripId}
       * @allow (create) An authenticated user can create a new trip under their own profile.
       * @deny (get) Another user cannot read a user's trip document.
       * @principle Enforces document ownership for all operations on a user's private data.
       */
      match /trips/{tripId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Controls access to the days within a user's trip.
         * @path /users/{userId}/trips/{tripId}/days/{dayId}
         * @allow (list) The trip owner can list all days within their trip.
         * @deny (create) An unauthenticated user cannot create a day in someone's trip.
         * @principle Path-based ownership ensures that all nested data remains private to the user.
         */
        match /days/{dayId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.tripId == tripId;
          allow update: if isExistingOwner(userId) && request.resource.data.tripId == resource.data.tripId;
          allow delete: if isExistingOwner(userId);

          /**
           * @description Controls access to specific events within a day of a trip.
           * @path /users/{userId}/trips/{tripId}/days/{dayId}/events/{eventId}
           * @allow (update) The trip owner can update an event in their itinerary.
           * @deny (delete) Another user cannot delete an event from a trip.
           * @principle Validates relational integrity by ensuring the event's `dayId` matches its path.
           */
          match /events/{eventId} {
            allow get: if isOwner(userId);
            allow list: if isOwner(userId);
            allow create: if isOwner(userId) && request.resource.data.dayId == dayId;
            allow update: if isExistingOwner(userId) && request.resource.data.dayId == resource.data.dayId;
            allow delete: if isExistingOwner(userId);

            /**
             * @description Controls access to AI enrichment data for a specific event.
             * @path /users/{userId}/trips/{tripId}/days/{dayId}/events/{eventId}/enrichments/{enrichmentId}
             * @allow (create) The trip owner can create an enrichment record for their event.
             * @deny (get) Public or other users cannot read raw AI responses.
             * @principle Deeply nested data inherits ownership from the top-level path, ensuring consistent security.
             */
            match /enrichments/{enrichmentId} {
              allow get: if isOwner(userId);
              allow list: if isOwner(userId);
              allow create: if isOwner(userId) && request.resource.data.eventId == eventId;
              allow update: if isExistingOwner(userId) && request.resource.data.eventId == resource.data.eventId;
              allow delete: if isExistingOwner(userId);
            }
          }
        }
      }
    }
  }
}